# AuthStart Web App Environment Configuration

# Laravel API base URL (must include /api)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Laravel storage base URL (used for logos, avatars, favicons)
VITE_STORAGE_BASE_URL=http://127.0.0.1:8000

# App title override (optional)
# VITE_APP_TITLE=AuthStart
